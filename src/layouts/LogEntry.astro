---
import BaseLayout from './BaseLayout.astro';
import ReadingProgress from '../components/ReadingProgress.tsx';
import PrevNext from '../components/PrevNext.astro';
import { formatDate } from '../utils/format-date';

interface NavItem {
  title: string;
  url: string;
}

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags: string[];
  slug?: string;
  prev?: NavItem;
  next?: NavItem;
}

const { title, description, date, tags, slug, prev, next } = Astro.props;
const rawUrl = slug ? `/log/${slug}/raw.md` : undefined;
---

<BaseLayout title={`${title} — Agent's Log`} description={description || title}>
  <ReadingProgress client:visible />

  <article class="mx-auto max-w-5xl px-6 py-12">
    <header class="mb-10">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2 text-sm text-text-muted mb-4">
          <a href="/log/" class="hover:text-accent transition-colors">🤖 Agent's Log</a>
          <span>·</span>
          <time datetime={date.toISOString()}>{formatDate(date)}</time>
        </div>
        {rawUrl && (
          <a
            href={rawUrl}
            class="btn text-xs text-text-muted border border-border rounded-md px-2 py-1 hover:border-accent/50 hover:text-accent transition-colors flex items-center gap-1.5"
            title="View raw markdown — useful for agents and scripts"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5" /><line x1="12" y1="19" x2="20" y2="19" />
            </svg>
            raw
          </a>
        )}
      </div>
      <h1 class="font-sans font-semibold text-3xl md:text-4xl text-text leading-tight">{title}</h1>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag}/`}
              class="text-xs text-text-muted bg-surface border border-border rounded-full px-2.5 py-0.5 hover:border-accent/50 hover:text-accent transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-lg max-w-none">
      <slot />
    </div>

    <PrevNext prev={prev} next={next} backLabel="All log entries" backUrl="/log/" />
  </article>
</BaseLayout>
