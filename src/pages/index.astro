---
import BaseLayout from '../layouts/BaseLayout.astro';
import DotGrid from '../components/DotGrid.astro';
import FeedItem from '../components/FeedItem.astro';
import { getMergedFeed } from '../utils/merge-feeds';
import { projects } from '../data/projects';
import { Image } from 'astro:assets';
import meImage from '../assets/me.png';

const recentNotes = (await getMergedFeed()).slice(0, 6);
---

<BaseLayout title="Johnny Greco">
  <!-- Intro -->
  <section class="relative overflow-hidden">
    <DotGrid />
    <div class="relative mx-auto max-w-5xl px-6 py-16 md:py-24">
      <div class="flex flex-col md:flex-row gap-8 items-start">
        <Image
          src={meImage}
          alt="Johnny Greco"
          width={120}
          height={120}
          class="rounded-2xl border-2 border-border flex-shrink-0"
        />
        <div>
          <h1 class="text-4xl md:text-5xl font-bold text-text">
            👋 hey, i'm johnny
          </h1>
          <p class="mt-4 text-lg text-text-muted max-w-2xl leading-relaxed">
            AI engineer and former astronomer. I used to hunt for galaxies —
            now I build with AI agents.
          </p>
          <div class="flex items-center gap-4 mt-6">
            <a href="https://github.com/johnnygreco" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="GitHub">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            </a>
            <a href="https://linkedin.com/in/johnnygreco" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="LinkedIn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="https://x.com/johnnypgreco" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="X">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://scholar.google.com/citations?user=CDWpgoAAAAAJ" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label="Google Scholar">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>
            </a>
            <a href="mailto:jgreco.ai@gmail.com" class="text-text-muted hover:text-accent transition-colors" aria-label="Email">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Project Spotlight -->
      <div class="mt-12 max-w-2xl" id="project-spotlight">
        <h2 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-3">🔦 Project Spotlight</h2>
        {projects.map((project) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="hidden group rounded-xl border border-border/60 bg-surface/50 hover:border-accent/30 hover:bg-surface transition-all duration-200 overflow-hidden"
            data-spotlight
          >
            <div class="flex flex-col sm:flex-row">
              <div class="sm:w-48 flex-shrink-0 border-b sm:border-b-0 sm:border-r border-border/40">
                {project.image ? (
                  <Image
                    src={project.image}
                    alt={project.name}
                    width={192}
                    height={128}
                    class="w-full h-32 sm:h-full object-cover"
                  />
                ) : (
                  <div class="w-full h-32 sm:h-full min-h-[8rem] bg-gradient-to-br from-accent/10 to-accent/5 flex items-center justify-center">
                    <span class="text-4xl font-bold text-accent/25">{project.name.charAt(0).toUpperCase()}</span>
                  </div>
                )}
              </div>
              <div class="p-4 flex-1 min-w-0">
                <h3 class="font-semibold text-text group-hover:text-accent transition-colors flex items-center gap-2">
                  {project.name}
                  <svg class="w-3 h-3 opacity-30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M15 3h6v6" /><path d="M10 14 21 3" />
                  </svg>
                </h3>
                <p class="text-sm text-text-muted mt-1.5 leading-relaxed line-clamp-2">{project.description}</p>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {project.tags.map((tag) => (
                    <span class="text-xs text-text-muted bg-bg/50 rounded-full px-2 py-0.5">#{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      function pickSpotlight() {
        var cards = document.querySelectorAll('[data-spotlight]');
        if (cards.length === 0) return;
        var idx = Math.floor(Math.random() * cards.length);
        for (var i = 0; i < cards.length; i++) {
          if (i === idx) cards[i].classList.remove('hidden');
          else cards[i].classList.add('hidden');
        }
      }
      pickSpotlight();
      document.addEventListener('astro:after-swap', pickSpotlight);
    })();
  </script>

  <!-- Recent Notes -->
  {recentNotes.length > 0 && (
    <section class="mx-auto max-w-5xl px-6 py-12 border-t border-border">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wider">📝 Recent Notes</h2>
        <a href="/notes/" class="text-sm text-accent hover:text-accent-hover transition-colors">View all →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {recentNotes.map((item) => <FeedItem item={item} />)}
      </div>
    </section>
  )}
</BaseLayout>
