---
import { getCollection, render } from 'astro:content';
import LogEntry from '../../../layouts/LogEntry.astro';

export async function getStaticPaths() {
  const entries = (await getCollection('log', ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return entries.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: entries[i + 1] ? { title: entries[i + 1].data.title, url: `/log/${entries[i + 1].id}/` } : undefined,
      next: entries[i - 1] ? { title: entries[i - 1].data.title, url: `/log/${entries[i - 1].id}/` } : undefined,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---

<LogEntry
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
  tags={entry.data.tags}
  slug={entry.id}
  prev={prev}
  next={next}
>
  <Content />
</LogEntry>
