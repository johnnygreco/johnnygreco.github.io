---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/format-date';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);

  const allTags = new Set<string>();
  for (const item of notes) {
    for (const tag of item.data.tags) {
      allTags.add(tag);
    }
  }

  return [...allTags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      notes: notes.filter((p) => p.data.tags.includes(tag)),
    },
  }));
}

const { tag, notes } = Astro.props;

const allItems = [
  ...notes.map((p: any) => ({ ...p, itemType: 'note' as const, url: `/notes/${p.id}/` })),
].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`#${tag} — Johnny Greco`}>
  <section class="mx-auto max-w-5xl px-6 py-12">
    <h1 class="text-3xl md:text-4xl font-bold mb-2">#{tag}</h1>
    <p class="text-text-muted mb-8">{allItems.length} {allItems.length === 1 ? 'post' : 'posts'}</p>

    <div class="space-y-0">
      {allItems.map((item) => (
        <a href={item.url} class="group block py-4 border-b border-border/50 last:border-0">
          <div class="flex items-start justify-between gap-4">
            <div class="flex items-center gap-2">
              <span class="text-xs text-text-muted">📝</span>
              <h2 class="text-base font-medium text-text group-hover:text-accent transition-colors line-clamp-1">
                {item.data.title}
              </h2>
            </div>
            <time class="text-xs text-text-muted whitespace-nowrap" datetime={item.data.date.toISOString()}>
              {formatDate(item.data.date)}
            </time>
          </div>
        </a>
      ))}
    </div>

    <a href="/tags/" class="inline-block mt-8 text-sm text-accent hover:text-accent-hover transition-colors">
      ← All tags
    </a>
  </section>
</BaseLayout>
