---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { projects } from '../data/projects';
---

<BaseLayout title="Projects — Johnny Greco" description="Open source and side projects.">
  <section class="mx-auto max-w-5xl px-6 py-12">
    <h1 class="text-3xl md:text-4xl font-bold mb-8">🏗️ Projects</h1>

    <div class="grid gap-6">
      {projects.map((project) => (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block rounded-xl border border-border bg-surface overflow-hidden hover:border-accent/50 transition-colors"
        >
          <div class:list={[
            'flex flex-col',
            project.image && 'md:flex-row',
          ]}>
            {project.image && (
              <div class="md:w-72 lg:w-80 flex-shrink-0 bg-bg overflow-hidden">
                <Image
                  src={project.image}
                  alt={`${project.name} project`}
                  width={320}
                  height={213}
                  class="w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity"
                />
              </div>
            )}
            <div class="p-5 flex flex-col justify-center min-w-0">
              <div class="flex items-start justify-between gap-4">
                <h2 class="text-lg font-semibold text-text group-hover:text-accent transition-colors">
                  {project.name}
                </h2>
                <svg class="flex-shrink-0 w-4 h-4 text-text-muted mt-1 opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M15 3h6v6" /><path d="M10 14 21 3" />
                </svg>
              </div>
              <p class="text-sm text-text-muted mt-2 leading-relaxed">{project.description}</p>
              {project.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {project.tags.map((tag) => (
                    <span class="text-xs text-text-muted bg-bg border border-border/50 rounded-full px-2 py-0.5">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
