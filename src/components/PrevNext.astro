---
interface NavItem {
  title: string;
  url: string;
}

interface Props {
  prev?: NavItem;
  next?: NavItem;
  backLabel?: string;
  backUrl?: string;
}

const { prev, next, backLabel = 'Back', backUrl } = Astro.props;
const hasPrevNext = prev || next;
---

<nav class="mt-12 pt-8 border-t border-border" aria-label="Post navigation">
  {backUrl && (
    <div class="mb-6">
      <a href={backUrl} class="inline-flex items-center gap-1.5 text-sm text-text-muted hover:text-accent transition-colors">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6" />
        </svg>
        {backLabel}
      </a>
    </div>
  )}

  {hasPrevNext && (
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {prev ? (
        <a href={prev.url} class="group flex items-start gap-3 p-4 rounded-xl border border-border/60 bg-surface/50 hover:border-accent/30 transition-all">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5 text-text-muted group-hover:text-accent transition-colors">
            <polyline points="15 18 9 12 15 6" />
          </svg>
          <div class="min-w-0">
            <span class="text-xs text-text-muted uppercase tracking-wider">Previous</span>
            <p class="text-sm font-semibold text-text group-hover:text-accent transition-colors mt-1 line-clamp-2">
              {prev.title}
            </p>
          </div>
        </a>
      ) : (
        <div />
      )}

      {next ? (
        <a href={next.url} class="group flex items-start gap-3 p-4 rounded-xl border border-border/60 bg-surface/50 hover:border-accent/30 transition-all sm:text-right sm:flex-row-reverse">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5 text-text-muted group-hover:text-accent transition-colors">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <div class="min-w-0">
            <span class="text-xs text-text-muted uppercase tracking-wider">Next</span>
            <p class="text-sm font-semibold text-text group-hover:text-accent transition-colors mt-1 line-clamp-2">
              {next.title}
            </p>
          </div>
        </a>
      ) : (
        <div />
      )}
    </div>
  )}
</nav>
